<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.TitleNonHTML}}</title>
    <link rel="icon" href="/assets/ashouri-favicon.svg" type="image/svg+xml">
    <style>
        :root {
            --bg: #081111;
            --panel: rgba(16, 26, 26, 0.9);
            --ink: #e8f0e8;
            --muted: #91a39c;
            --line: #263939;
            --line-strong: #3c5552;
            --accent: #49e58f;
            --quote: #101a1a;
        }

        body {
            font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background:
                linear-gradient(rgba(73, 229, 143, 0.035) 1px, transparent 1px),
                linear-gradient(90deg, rgba(73, 229, 143, 0.035) 1px, transparent 1px),
                radial-gradient(circle at 50% -12rem, rgba(73, 229, 143, 0.16), transparent 34rem),
                var(--bg);
            background-size: 28px 28px, 28px 28px, auto, auto;
            color: var(--ink);
            margin: 0;
            padding: 0 1rem 4rem;
        }

        .container {
            max-width: 760px;
            margin: 2.5rem auto;
            padding: 1.75rem;
            border: 1px solid var(--line);
            background: var(--panel);
        }

        h1 {
            margin: 0 0 1.5rem;
            color: var(--ink);
            font-size: clamp(2.1rem, 6vw, 3.5rem);
            font-weight: 750;
            line-height: 1.08;
            letter-spacing: -0.05em;
        }

        blockquote {
            margin: 1.5rem 0;
            padding: 1rem 1.25rem;
            border-left: 4px solid var(--accent);
            background-color: var(--quote);
            color: var(--ink);
        }

        a {
            color: var(--accent);
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }

        p {
            color: var(--ink);
            line-height: 1.8;
        }

        code, pre {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
        }

        .back-link {
            max-width: 760px;
            margin: 1.5rem auto 0;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
            font-size: 0.95rem;
        }

        @media (max-width: 640px) {
            .container {
                padding: 1.25rem;
            }
        }
    </style>
</head>
<body>
    <div class="back-link">
        <a href="/">← Back to Home</a> <!-- Link to the homepage -->
    </div>

    <div class="container">
        <h1>{{.Title}}</h1>

        <div class="blog-post" id="blog-post-container">
            <!-- Blog post content will be displayed here -->
            {{.Content}}
        </div>
    </div>
</body>
</html>
