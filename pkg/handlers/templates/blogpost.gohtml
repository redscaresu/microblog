<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.TitleNonHTML}}</title>
    <link rel="icon" href="/assets/ashouri-favicon.svg" type="image/svg+xml">
    <style>
        :root {
            --paper: #f5f0e6;
            --panel: rgba(255, 252, 247, 0.82);
            --ink: #202829;
            --muted: #626a68;
            --line: #cfc5b6;
            --accent: #9a3f2b;
            --quote: #ebe2d5;
        }

        body {
            font-family: Georgia, "Times New Roman", serif;
            background:
                linear-gradient(rgba(32, 40, 41, 0.035) 1px, transparent 1px),
                linear-gradient(90deg, rgba(32, 40, 41, 0.035) 1px, transparent 1px),
                radial-gradient(circle at 50% -12rem, rgba(154, 63, 43, 0.14), transparent 34rem),
                var(--paper);
            background-size: 28px 28px, 28px 28px, auto, auto;
            color: var(--ink);
            margin: 0;
            padding: 0 1rem 4rem;
        }

        .container {
            max-width: 760px;
            margin: 2.5rem auto;
            padding: 1.75rem;
            border: 1px solid var(--line);
            background: var(--panel);
            backdrop-filter: blur(10px);
        }

        h1 {
            margin: 0 0 1.5rem;
            color: var(--ink);
            font-size: clamp(2.1rem, 6vw, 3.5rem);
            font-weight: 400;
            line-height: 1.08;
            letter-spacing: 0;
        }

        blockquote {
            margin: 1.5rem 0;
            padding: 1rem 1.25rem;
            border-left: 4px solid var(--accent);
            background-color: var(--quote);
            color: var(--ink);
            font-style: italic;
        }

        a {
            color: var(--accent);
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }

        p {
            color: var(--ink);
            line-height: 1.8;
        }

        code, pre {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
        }

        .back-link {
            max-width: 760px;
            margin: 1.5rem auto 0;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
            font-size: 0.95rem;
        }

        @media (max-width: 640px) {
            .container {
                padding: 1.25rem;
            }
        }
    </style>
</head>
<body>
    <div class="back-link">
        <a href="/">← Back to Home</a> <!-- Link to the homepage -->
    </div>

    <div class="container">
        <h1>{{.Title}}</h1>

        <div class="blog-post" id="blog-post-container">
            <!-- Blog post content will be displayed here -->
            {{.Content}}
        </div>
    </div>
</body>
</html>
