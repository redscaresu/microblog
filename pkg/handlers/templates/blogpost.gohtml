<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.TitleNonHTML}}</title>
    <link rel="icon" href="/assets/ashouri-favicon.svg" type="image/svg+xml">
    <style>
        :root {
            --paper: #f5f0e6;
            --ink: #202829;
            --muted: #626a68;
            --line: #cfc5b6;
            --accent: #9a3f2b;
            --quote: #ebe2d5;
        }

        body {
            font-family: Georgia, "Times New Roman", serif;
            background-color: var(--paper);
            color: var(--ink);
            margin: 0;
            padding: 0 1rem 4rem;
        }

        .container {
            max-width: 760px;
            margin: 2.5rem auto;
            padding-top: 1.75rem;
            border-top: 1px solid var(--line);
        }

        h1 {
            margin: 0 0 1.5rem;
            color: var(--ink);
            font-size: clamp(2.1rem, 6vw, 3.5rem);
            font-weight: 400;
            line-height: 1.08;
            letter-spacing: 0;
        }

        blockquote {
            margin: 1.5rem 0;
            padding: 1rem 1.25rem;
            border-left: 4px solid var(--accent);
            background-color: var(--quote);
            font-style: italic;
        }

        a {
            color: var(--accent);
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }

        p {
            color: var(--ink);
            line-height: 1.8;
        }

        .back-link {
            max-width: 760px;
            margin: 1.5rem auto 0;
            font-family: Arial, sans-serif;
            font-size: 0.95rem;
        }
    </style>
</head>
<body>
    <div class="back-link">
        <a href="/">← Back to Home</a> <!-- Link to the homepage -->
    </div>

    <div class="container">
        <h1>{{.Title}}</h1>

        <div class="blog-post" id="blog-post-container">
            <!-- Blog post content will be displayed here -->
            {{.Content}}
        </div>
    </div>
</body>
</html>
